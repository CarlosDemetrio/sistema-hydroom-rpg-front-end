{
  "name": "ficha-controlador-front-end",
  "version": "0.0.0",
  "web-types": "./.idea/primeng-web-types.json",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201 --proxy-config proxy.conf.json",
    "start:local": "ng serve --port 4201 --proxy-config proxy.conf.local.json",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 ng test",
    "test:coverage": "NODE_OPTIONS=--max-old-space-size=8192 ng test --coverage --watch=false",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/signals": "^21.0.1",
    "@primeng/themes": "^21.0.4",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/angular": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
